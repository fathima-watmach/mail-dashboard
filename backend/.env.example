# Copy this file to .env and fill in your real values.
# .env is already in .gitignore - never commit real secrets.

# ---- Supabase / Postgres ----
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Azure AD / Microsoft Graph (Outlook) ----
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=common
AZURE_CLIENT_SECRET=your-azure-client-secret
# Local dev:
# AZURE_REDIRECT_URI=http://localhost:3001/auth/callback
# Production:
AZURE_REDIRECT_URI=https://your-app.onrender.com/auth/callback

# ---- Zoho Mail ----
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
# Local dev:
# ZOHO_REDIRECT_URI=http://localhost:3001/auth/zoho/callback
# Production:
ZOHO_REDIRECT_URI=https://your-app.onrender.com/auth/zoho/callback

# ---- AI Classification ----
# Use "gemini" for free production use (1M tokens/min free tier — no rate limit issues)
CLASSIFIER_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key        # get from aistudio.google.com
GEMINI_MODEL=gemini-2.0-flash             # used for thread summaries
GEMINI_CLASSIFY_MODEL=gemini-2.0-flash    # used for email classification

# ---- Optional: DeepSeek / Groq (legacy) ----
# CLASSIFIER_PROVIDER=groq
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_CLASSIFY_MODEL=llama-3.1-8b-instant

# ---- App ----
NODE_ENV=production
PORT=3001
SESSION_SECRET=generate-a-long-random-string-here
# Local dev: FRONTEND_URL=http://localhost:5173
FRONTEND_URL=https://your-app.onrender.com
